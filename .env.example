# Copy this file to .env and fill in your key.
# .env is git-ignored. Never commit your real key.
#
# On Streamlit Cloud: add this via the Secrets UI (Settings > Secrets),
# not as a file. The get_secret() helper in src/config.py handles both.
OPENAI_API_KEY=your_key_here

# Adzuna API — used only for data ingestion (scripts/fetch_adzuna_jobs.py)
# Register at https://developer.adzuna.com/ to get these.
# Not needed at runtime — only needed when rebuilding job_descriptions.csv.
ADZUNA_APP_ID=your_app_id_here
ADZUNA_APP_KEY=your_app_key_here